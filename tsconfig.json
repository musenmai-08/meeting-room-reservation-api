{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": ".",
		"paths": {
			"@application/*": ["./src/application/*"],
			"@domain/*": ["./src/domain/*"],
			"@infrastructure/*": ["./src/infrastructure/*"]
		},
		"types": ["node"]
	},
	"include": ["src", "tests"],
	"exclude": ["node_modules", "dist"]
}
